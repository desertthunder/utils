{
  "typescript": {
    "lineWidth": 120,
    "indentWidth": 2,
    "semiColons": "always",
    "preferSingleLine": true,
    "jsx.bracketPosition": "sameLine"
  },
  "json": { "lineWidth": 120, "indentWidth": 2, "preferSingleLine": true },
  "markdown": { "lineWidth": 80 },
  "includes": ["**/*.{ts,tsx,js,jsx,json,jsonc,md}"],
  "excludes": ["node_modules", ".wrangler", "public/assets/fonts", "worker-configuration.d.ts"],
  "plugins": [
    "https://plugins.dprint.dev/typescript-0.96.1.wasm",
    "https://plugins.dprint.dev/json-0.21.3.wasm",
    "https://plugins.dprint.dev/markdown-0.22.1.wasm"
  ]
}
